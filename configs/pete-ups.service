[Unit]
Description=Pete motherbrain Geekworm X1202 monitor
After=local-fs.target

[Service]
Type=simple
ExecStart=/usr/local/bin/pete-ups --profile /etc/pete/x1202.toml monitor --interval-seconds 2 --critical-percent 10 --critical-samples 5
Restart=on-failure
RestartSec=5
RuntimeDirectory=pete
RuntimeDirectoryMode=0750
UMask=0007

[Install]
WantedBy=multi-user.target
