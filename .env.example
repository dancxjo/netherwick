RUST_LOG=info

NETHERWICK_LIVE_PORT=8787
NETHERWICK_SIM_STEPS=1000000000
NETHERWICK_TICK_DELAY_MS=100

NETHERWICK_NEO4J_USER=neo4j
NETHERWICK_NEO4J_PASSWORD=password
NETHERWICK_NEO4J_HTTP_PORT=7474
NETHERWICK_NEO4J_BOLT_PORT=7687

NETHERWICK_QDRANT_HTTP_PORT=6333
NETHERWICK_QDRANT_GRPC_PORT=6334
NETHERWICK_QDRANT_URL=http://127.0.0.1:6333

NETHERWICK_TTS_PIPER_VOICE=${HOME}/.local/share/tongues/models/piper/en_US-ryan-medium.onnx
NETHERWICK_TTS_PIPER_CONFIG=${HOME}/.local/share/tongues/models/piper/en_US-ryan-medium.onnx.json
NETHERWICK_TTS_OUTPUT_DEVICE="USB Audio Device"
NETHERWICK_TTS_VARIETY=en-US
ORT_DYLIB_PATH=.vendor/onnxruntime/onnxruntime-linux-aarch64-1.22.0/lib/libonnxruntime.so
MIC_DEVICE=default
NETHERWICK_WHISPER_MODEL=${HOME}/.local/share/netherwick/models/whisper/ggml-base.en.bin
NETHERWICK_ASR_COMMAND="target/debug/netherwick whisper-transcribe"

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:20b
NETHERWICK_LLM_ENDPOINT=http://127.0.0.1:11434
NETHERWICK_LLM_MODEL=gpt-oss:20b
NETHERWICK_IMAGE_DESCRIPTION_MODEL=gemma4
IMAGE_DESCRIPTION_MODEL=gemma4
NETHERWICK_EMBEDDINGS_MODEL=embeddinggemma
EMBEDDINGS_MODEL=embeddinggemma
