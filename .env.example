RUST_LOG=info

# Brainstem AP lease. DHCP client ID is lowercase hex for option 61; the
# NetworkManager default is 01 followed by the Wi-Fi adapter MAC address.
PETE_BRAINSTEM_WIFI_IPV4=192.168.4.2
PETE_DHCP_CLIENT_ID_HEX=01xxxxxxxxxxxx
PETE_BRAINSTEM_INTERFACE=wlxXXXXXXXXXXXX
# Pin these from the identity and boot values printed by motherbrain_bootstrap.
PETE_BRAINSTEM_DEVICE_ID=
PETE_BRAINSTEM_BOOT_ID=
# PETE_COCKPIT_PORT=/dev/serial/by-id/DEVICE

PETE_LIVE_PORT=8787
PETE_SIM_STEPS=1000000000
PETE_TICK_DELAY_MS=100

PETE_NEO4J_USER=neo4j
PETE_NEO4J_PASSWORD=password
PETE_NEO4J_HTTP_PORT=7474
PETE_NEO4J_BOLT_PORT=7687

PETE_QDRANT_HTTP_PORT=6333
PETE_QDRANT_GRPC_PORT=6334
PETE_QDRANT_URL=http://127.0.0.1:6333

PETE_TTS_PIPER_VOICE=${HOME}/.local/share/tongues/models/piper/en_US-ryan-medium.onnx
PETE_TTS_PIPER_CONFIG=${HOME}/.local/share/tongues/models/piper/en_US-ryan-medium.onnx.json
PETE_TTS_OUTPUT_DEVICE=
PETE_TTS_VARIETY=en-US
MIC_DEVICE=default
PETE_WHISPER_MODEL=${HOME}/.local/share/pete/models/whisper/ggml-base.en.bin
PETE_ASR_COMMAND="target/debug/pete whisper-transcribe"

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:20b
PETE_LLM_ENDPOINT=http://127.0.0.1:11434
PETE_LLM_MODEL=gpt-oss:20b
PETE_IMAGE_DESCRIPTION_MODEL=gemma4
IMAGE_DESCRIPTION_MODEL=gemma4
PETE_EMBEDDINGS_MODEL=embeddinggemma
EMBEDDINGS_MODEL=embeddinggemma
